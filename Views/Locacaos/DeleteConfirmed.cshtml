@model DriveNow.MVC.Models.LocacaoView

<div class="container mt-4">
    <h2 class="text-danger">Excluir Locação</h2>
    <h3>Tem certeza que deseja remover esta locação?</h3>
    <hr />

    <div class="card bg-light">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">ID da Locação</dt>
                <dd class="col-sm-9">@Model.Id</dd>

                <dt class="col-sm-3">Cliente</dt>
                <dd class="col-sm-9">@(Model.ClienteNome ?? "Não informado")</dd>

                <dt class="col-sm-3">Veículo</dt>
                <dd class="col-sm-9">@(Model.VeiculoIdentificador ?? "Não informado")</dd>

                <dt class="col-sm-3">Data de Retirada</dt>
                <dd class="col-sm-9">@Model.DataRetirada.ToString("dd/MM/yyyy HH:mm")</dd>

                <dt class="col-sm-3">Valor Total</dt>
                <dd class="col-sm-9">@Model.ValorTotal.ToString("C")</dd>
            </dl>
        </div>
    </div>

    <form asp-action="DeleteConfirmed" class="mt-4">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Confirmar Exclusão</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>