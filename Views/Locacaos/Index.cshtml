@model IEnumerable<DriveNow.MVC.Models.LocacaoView>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2>Histórico de Locações</h2>
        <a asp-action="Create" class="btn btn-success">Nova Locação</a>
    </div>

    <table class="table table-striped mt-4">
        <thead class="thead-dark">
            <tr>
                <th>ID</th>
                <th>Cliente</th>
                <th>Veículo</th>
                <th>Retirada</th>
                <th>Devolução</th>
                <th>Total</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var locacao in Model)
            {
                <tr>
                    <td>@locacao.Id</td>
                    <td>@(locacao.ClienteNome ?? "N/A")</td>
                    <td>@(locacao.VeiculoIdentificador ?? "N/A")</td>
                    <td>@locacao.DataRetirada.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@locacao.DataDevolucao.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@locacao.ValorTotal.ToString("C")</td>
                    <td>
                        <a asp-action="Delete" asp-route-id="@locacao.Id" class="btn btn-sm btn-outline-danger">Deletar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>